{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/dsc-v3-discovery/schemas/assignments.json",
  "title": "DSC v3 fleet assignments",
  "description": "Maps server groups to DSC v3 configuration documents and an enforcement schedule, plus rules for deciding which groups a server belongs to.",
  "type": "object",
  "additionalProperties": false,
  "required": ["groups", "membership"],
  "properties": {
    "$schema": { "type": "string" },
    "groups": {
      "description": "Named groups. The implicit 'all' group always matches every server.",
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/group" }
    },
    "membership": {
      "description": "Per-group rules deciding whether the current server is in the group. Order does not matter; a server is in a group when ANY rule matches.",
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/$defs/membershipRule" }
      }
    }
  },
  "$defs": {
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schedule", "configs"],
      "properties": {
        "schedule": {
          "description": "How often this group's configs should be applied.",
          "type": "string",
          "pattern": "^(OnDemand|Hourly|Daily [0-2][0-9]:[0-5][0-9]|Every[0-9]+(Minutes|Hours))$"
        },
        "mode": {
          "description": "set = enforce; test = report-only (Test+report, never Set).",
          "type": "string",
          "enum": ["set", "test"],
          "default": "set"
        },
        "configs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "description": "Path or glob, repo-root relative." }
        }
      }
    },
    "membershipRule": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": { "type": { "const": "all" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "pattern"],
          "properties": {
            "type":    { "const": "hostname" },
            "pattern": { "type": "string", "description": "Regex matched against $env:COMPUTERNAME (case-insensitive)." }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "key", "value"],
          "properties": {
            "type":  { "const": "arcTag" },
            "key":   { "type": "string" },
            "value": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "value"],
          "properties": {
            "type":  { "const": "adGroup" },
            "value": { "type": "string", "description": "AD group sAMAccountName the computer must be a member of." }
          }
        }
      ]
    }
  }
}
